@startuml
title Filmoteca – Use Case Diagram

actor "User" as user
actor "Administrator" as admin
actor "Content Manager" as manager

rectangle Filmoteca {
  
  ' --- Content Module ---
  usecase "Browse Catalog" as UC1
  usecase "Search Content" as UC2
  usecase "View Details" as UC3
  usecase "Rate Content" as UC4
  usecase "Add to Watchlist" as UC5
  usecase "Play Trailer" as UC6

  ' --- User Module ---
  usecase "Register" as UC7
  usecase "Login" as UC8
  usecase "Update Profile" as UC9
  usecase "Manage Watchlist" as UC10

  ' --- Administration Module ---
  usecase "Add Content" as UC11
  usecase "Update Content" as UC12
  usecase "Delete Content" as UC13
  usecase "Generate Reports" as UC14
  usecase "Manage Users" as UC15
}

' --- Relationships ---
user --> UC1
user --> UC2
user --> UC3
user --> UC4
user --> UC5
user --> UC6
user --> UC7
user --> UC8
user --> UC9
user --> UC10

manager --> UC11
manager --> UC12
manager --> UC13

admin --> UC14
admin --> UC15
@enduml
